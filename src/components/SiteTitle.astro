---
import lightLogo from '../assets/cloudless-computer-sun-logo-light.svg?raw';
import darkLogo from '../assets/cloudless-computer-sun-logo-dark.svg?raw';
---

<a href="/" class="site-title sl-flex">
	<span class="light-logo" set:html={lightLogo} />
	<span class="dark-logo" set:html={darkLogo} />
</a>

<style>
	.site-title {
		align-items: center;
		gap: var(--sl-nav-gap);
		text-decoration: none;
		white-space: nowrap;
	}
	.light-logo,
	.dark-logo {
		display: flex;
		align-items: center;
	}
	.light-logo :global(svg),
	.dark-logo :global(svg) {
		height: 3rem;
		width: auto;
	}

	/* Default: show light logo */
	.dark-logo {
		display: none;
	}

	/* Explicit dark theme */
	:global([data-theme='dark']) .light-logo {
		display: none;
	}
	:global([data-theme='dark']) .dark-logo {
		display: flex;
	}

	/* Explicit light theme */
	:global([data-theme='light']) .dark-logo {
		display: none;
	}
	:global([data-theme='light']) .light-logo {
		display: flex;
	}

	/* No explicit theme — follow system preference */
	@media (prefers-color-scheme: dark) {
		:global(:root:not([data-theme])) .light-logo {
			display: none;
		}
		:global(:root:not([data-theme])) .dark-logo {
			display: flex;
		}
	}
</style>
