---
---

<theme-toggle>
  <button type="button" class="theme-toggle" aria-label="Toggle theme">
    <svg class="icon icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
    <svg class="icon icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>
</theme-toggle>

<script>
  type Theme = 'dark' | 'light';

  class ThemeToggle extends HTMLElement {
    button: HTMLButtonElement | null = null;

    connectedCallback() {
      this.button = this.querySelector('.theme-toggle');
      this.init();
    }

    getTheme(): Theme {
      const stored = localStorage.getItem('starlight-theme');
      if (stored === 'dark' || stored === 'light') return stored;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    setTheme(theme: Theme) {
      document.documentElement.dataset.theme = theme;
      localStorage.setItem('starlight-theme', theme);
      const moonIcon = this.button?.querySelector('.icon-moon');
      const sunIcon = this.button?.querySelector('.icon-sun');
      if (moonIcon && sunIcon) {
        moonIcon.style.display = theme === 'dark' ? 'block' : 'none';
        sunIcon.style.display = theme === 'light' ? 'block' : 'none';
      }
    }

    init() {
      this.setTheme(this.getTheme());
      this.button?.addEventListener('click', () => {
        const next = this.getTheme() === 'dark' ? 'light' : 'dark';
        this.setTheme(next);
      });
    }
  }

  customElements.define('theme-toggle', ThemeToggle);
</script>

<style>
  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.25rem;
    padding: 0.25rem;
    line-height: 1;
    color: inherit;
  }

  .icon {
    width: 1.25em;
    height: 1.25em;
    vertical-align: middle;
  }

  .icon-moon {
    display: none;
  }

  .icon-sun {
    display: block;
  }

  :global([data-theme="dark"]) .icon-moon {
    display: block;
  }

  :global([data-theme="dark"]) .icon-sun {
    display: none;
  }
</style>
